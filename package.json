{
	"name": "@jayden/jai-mono",
	"private": true,
	"version": "1.0.0",
	"description": "Jai Mono is a monorepo for Jayden's projects.",
	"workspaces": {
		"packages": ["packages/*", "app/*"],
		"catalog": {
			"typescript": "^5.8",
			"zod": "^4.3.6"
		}
	},
	"scripts": {
		"lint": "biome check .",
		"lint:fix": "biome check --write .",
		"format": "biome format --write .",
    "desktop:dev": "cd app/desktop && bun dev"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.9",
		"@types/node": "^25.5.0",
		"bun-types": "^1.3.11",
		"typescript": "^5.8"
	}
}
