{
	"$schema": "https://biomejs.dev/schemas/2.4.9/schema.json",
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true,
			"style": {
				"noNonNullAssertion": "off",
				"useConst": "error",
				"useNodejsImportProtocol": "off"
			},
			"suspicious": {
				"noExplicitAny": "off",
				"noControlCharactersInRegex": "off",
				"noEmptyInterface": "off"
			}
		}
	},
	"formatter": {
		"enabled": true,
		"formatWithErrors": false,
		"indentStyle": "tab",
		"indentWidth": 3,
		"lineWidth": 120
	},
	"files": {
		"includes": [
			"packages/*/src/**/*.ts",
			"packages/*/test/**/*.ts",
			"app/*/src/**/*.{ts,tsx}",
			"app/*/electron/**/*.ts"
		],
		"ignores": [
			"**/node_modules/**",
			"**/dist/**",
			"**/models-snapshot.json",
			"**/test/*.test.ts",
			"**/components/ui/**",
			"**/components/ai-elements/**"
		]
	}
}
