{
	"$schema": "https://biomejs.dev/schemas/2.3.14/schema.json",
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true,
			"style": {
				"noNonNullAssertion": "off",
				"useConst": "error",
				"useNodejsImportProtocol": "off"
			},
			"suspicious": {
				"noExplicitAny": "off",
				"noControlCharactersInRegex": "off",
				"noEmptyInterface": "off"
			}
		}
	},
	"formatter": {
		"enabled": true,
		"formatWithErrors": false,
		"indentStyle": "tab",
		"indentWidth": 3,
		"lineWidth": 120
	},
	"files": {
		"includes": [
			"app/*/src/**/*.{ts,tsx}",
			"app/*/electron/**/*.ts",
			"packages/*/src/**/*.ts",
			"!**/test",
			"!**/node_modules",
			"!**/dist",
			"!**/models-snapshot.json",
			"!**/components/ui",
			"!**/components/ai-elements"
		]
	}
}
