{
	"extends": "./tsconfig.base.json",
	"compilerOptions": {
		"noEmit": true,
		"paths": {
			"@jayden/jai-utils": ["./packages/utils/src/index.ts"],
			"@jayden/jai-utils/*": ["./packages/utils/src/*"],
			"@jayden/jai-ai": ["./packages/ai/src/index.ts"],
			"@jayden/jai-ai/*": ["./packages/ai/src/*"],
			"@jayden/jai-agent": ["./packages/agent/src/index.ts"],
			"@jayden/jai-agent/*": ["./packages/agent/src/*"],
			"@jayden/jai-session": ["./packages/session/src/index.ts"],
			"@jayden/jai-session/*": ["./packages/session/src/*"],
			"@jayden/jai-coding-agent": ["./packages/coding-agent/src/index.ts"],
			"@jayden/jai-coding-agent/*": ["./packages/coding-agent/src/*"]
		}
	},
	"include": ["packages/*/src/**/*", "packages/*/test/**/*"],
	"exclude": ["**/dist/**"]
}
