{
	"extends": "../../tsconfig.base.json",
	"compilerOptions": {
		"jsx": "react-jsx",
		"target": "ESNext",
		"module": "ESNext",
		"lib": ["dom", "dom.iterable", "ESNext"],
		"noEmit": true,
		"declaration": false,
		"declarationMap": false,
		"sourceMap": true,
		"paths": {
			"@/*": ["./src/*"]
		},
		"outDir": "dist"
	},
	"include": [
		"src/**/*",
		"electron/**/*",
		"*.mts",
		"env.d.ts",
		"forge.env.d.ts",
		"forge.config.ts"
	]
}
